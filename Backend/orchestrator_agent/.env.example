# ============================================================
#  MediAssist-AI -- Orchestrator Agent -- Local Development .env
#
#  HOW SECRETS WORK:
#    On Azure App Service: Managed Identity fetches from Key Vault automatically.
#    Locally: DefaultAzureCredential uses the service principal below.
#
#  WHAT YOU MUST FILL IN (REPLACE_ values):
#    1. AZURE_KEY_VAULT_URI  -- from .deployment-summary.txt or Azure Portal
#    2. AZURE_TENANT_ID      -- your Azure Active Directory tenant ID
#    3. AZURE_CLIENT_ID      -- service principal app ID (see deployment-requirements.txt)
#    4. AZURE_CLIENT_SECRET  -- service principal secret
#    5. Endpoints (AZURE_OPENAI_ENDPOINT, OPENAI_ENDPOINT, AZURE_SEARCH_ENDPOINT)
#
#  All API keys and connection strings are fetched from Key Vault automatically.
# ============================================================

# ── Key Vault bootstrap ───────────────────────────────────────────────────────
# ─── Azure Managed Identity (for App Service) ────────────────────────────────
# When deployed to Azure App Service with Managed Identity enabled,
# these are NOT needed — @azure/identity DefaultAzureCredential handles it.
# Only set these for LOCAL development:
AZURE_TENANT_ID=baf5b083-4c53-493a-8af7-a6ae9812014c
AZURE_CLIENT_ID=b24341c2-7e09-4e72-89fd-1d176af84a1f
AZURE_CLIENT_SECRET=<secret>
# Need this for KeyVault
AZURE_KEY_VAULT_URI=https://kv-medai-e8976d87.vault.azure.net/

AZURE_OPENAI_ENDPOINT=https://aoai-mediassist-e8976d87.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=Conversation-Agent-Speaker-Tagging
AZURE_OPENAI_CHAT_DEPLOYMENT=Phi-4-mini-instruct
AZURE_OPENAI_DEPLOYEMENT=Phi-4-mini-instruct
AZURE_OPENAI_DEPLOYMENT=publishing_agent_model
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
ORCHESTRATION_DEPLOYMENT_NAME=Phi-4-mini-instruct
DEPLOYMENT_NAME=Conversation-Agent-Speaker-Tagging
OPENAI_ENDPOINT=https://aoai-mediassist-e8976d87.openai.azure.com/
SPEECH_REGION=eastus
AZURE_SEARCH_ENDPOINT=https://srch-mediassist-e8976d87.search.windows.net
AZURE_SEARCH_INDEX=az-med-cont1-index-final
AZURE_SEARCH_INDEX1=az-med-cont1-index2
AZURE_BLOB_CONTAINER_NAME=az-medassistai-container1
AZURE_BLOB_CONTAINER_NAME1=az-medassistai-container2
AZURE_BLOB_MEDICAL_KB_FILE=icd_10_cm_october_2025_guidelines_0.pdf
AZURE_BLOB_MEDICAL_KB_FILE1=section111_valid_icd10_october2025.csv
AZURE_BLOB_PDF_FILE=icd_10_cm_october_2025_guidelines_0.pdf
AZURE_BLOB_CSV_FILE=section111_valid_icd10_october2025.csv
MONGO_DB_NAME=medassist-ai-main-db
COSMOS_AUDIT_DB=medassist-ai-main-db
COSMOS_AUDIT_COLLECTION=pipeline_logs
MONGO_INPUT_COLLECTION=sample_inputs
MONGO_OUTPUT_COLLECTION=rag_outputs
NODEJS_BACKEND_URL=http://localhost:3000/api
USE_COSMOS=true
SPAWN_MAIN_AGENT_ON_REQUEST=true
START_MAIN_AGENT_ON_BOOT=false
MCP_COMMAND=python
MCP_ARGS=mcp_server/mcp_tools_server.py
